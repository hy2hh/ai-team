# ─── Anthropic / Claude Agent SDK 인증 ─────────────────────
# 기본: Console API 키 (ANTHROPIC_API_KEY). .env에만 두고 커밋하지 마세요.
# ANTHROPIC_API_KEY=sk-ant-...
#
# ./scripts/start-all.sh local → BRIDGE_ANTHROPIC_AUTH_MODE=claude_local 이 되어
# 로컬 `claude login` 계정(키체인) 요금제를 씁니다. .env에 이 모드를 넣지 않아도 됩니다.
# 로컬 계정과 다른 OAuth를 쓰려면 에이전트별로만 주입:
#   BRIDGE_CLAUDE_OAUTH_TOKEN_PM=...  (역할: PM, DESIGNER, FRONTEND, BACKEND, RESEARCHER, SECOPS, QA)
# 라우터·스레드 압축 등 비에이전트 호출: BRIDGE_CLAUDE_OAUTH_TOKEN_INFRA=...
#
# Claude.ai OAuth만 쓰는 모드(.env):
# BRIDGE_ANTHROPIC_AUTH_MODE=claude_oauth
# CLAUDE_CODE_OAUTH_TOKEN=...   # 전역, 또는 claude setup-token
# (선택) BRIDGE_CLAUDE_OAUTH_TOKEN=...
# 에이전트별 다른 계정: BRIDGE_CLAUDE_OAUTH_TOKEN_PM=... 등 (전역 토큰보다 우선)
# OAuth 모드에서는 ANTHROPIC_API_KEY가 구독을 덮어쓰므로 기본적으로 제거됩니다.
# API 키를 유지해야 하면: BRIDGE_OAUTH_KEEP_API_KEY=1
# (선택) BRIDGE_FORCE_LOGIN_ORG_UUID=...  # 팀 OAuth 시 org UUID
# (선택) BRIDGE_FORCE_LOGIN_ORG_UUID_PM=...  # 에이전트별 org
# refresh 흐름: CLAUDE_CODE_OAUTH_REFRESH_TOKEN + CLAUDE_CODE_OAUTH_SCOPES
#
# Slack Team
SLACK_TEAM_ID=T...
SLACK_WORKSPACE_DOMAIN=yourworkspace.slack.com

# 권한 승인 버튼 허용 사용자 (쉼표 구분, 기본값: sid)
SID_USER_ID=U...

# 봇 응답 허용 사용자 (쉼표 구분, 기본값: sid만 허용)
# 이 목록에 없는 사용자의 메시지는 게이트웨이에서 즉시 무시됩니다
ALLOWED_USER_IDS=U0AJ3T423RU

# PM Donald
SLACK_BOT_TOKEN_PM=xoxb-...
SLACK_APP_TOKEN_PM=xapp-...

# Designer Donald
SLACK_BOT_TOKEN_DESIGNER=xoxb-...
SLACK_APP_TOKEN_DESIGNER=xapp-...

# Frontend Donald
SLACK_BOT_TOKEN_FRONTEND=xoxb-...
SLACK_APP_TOKEN_FRONTEND=xapp-...

# Backend Donald
SLACK_BOT_TOKEN_BACKEND=xoxb-...
SLACK_APP_TOKEN_BACKEND=xapp-...

# Researcher Donald
SLACK_BOT_TOKEN_RESEARCHER=xoxb-...
SLACK_APP_TOKEN_RESEARCHER=xapp-...

# SecOps Donald
SLACK_BOT_TOKEN_SECOPS=xoxb-...
SLACK_APP_TOKEN_SECOPS=xapp-...

# QA Chalmers
SLACK_BOT_TOKEN_QA=xoxb-...
SLACK_APP_TOKEN_QA=xapp-...

# ─── Langfuse 관측성 ─────────────────────────────────────────
# 설정하면 에이전트 트레이스/스팬이 Langfuse 대시보드로 전송됩니다.
# 미설정 시 자동으로 비활성화 (브릿지 동작에 영향 없음).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # self-hosted 시 변경

# 에이전트 세션당 최대 턴 수 (기본값: 100, 루프 방지 + 비용 제어)
# BRIDGE_MAX_TURNS=100

# 위임 결과 텍스트 한도 (기본값: 3000)
# DELEGATION_RESULT_LIMIT=3000

# 회의 의견/결정 텍스트 한도 (기본값: 1000, 500)
# MEETING_OPINION_LIMIT=1000
# MEETING_DECISION_LIMIT=500


SLACK_USER_TOKEN=