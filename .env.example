# Slack Team
SLACK_TEAM_ID=T...
SLACK_WORKSPACE_DOMAIN=yourworkspace.slack.com

# 권한 승인 버튼 허용 사용자 (쉼표 구분, 기본값: sid)
SID_USER_ID=U...

# 봇 응답 허용 사용자 (쉼표 구분, 기본값: sid만 허용)
# 이 목록에 없는 사용자의 메시지는 게이트웨이에서 즉시 무시됩니다
ALLOWED_USER_IDS=U0AJ3T423RU

# PM Donald
SLACK_BOT_TOKEN_PM=xoxb-...
SLACK_APP_TOKEN_PM=xapp-...

# Designer Donald
SLACK_BOT_TOKEN_DESIGNER=xoxb-...
SLACK_APP_TOKEN_DESIGNER=xapp-...

# Frontend Donald
SLACK_BOT_TOKEN_FRONTEND=xoxb-...
SLACK_APP_TOKEN_FRONTEND=xapp-...

# Backend Donald
SLACK_BOT_TOKEN_BACKEND=xoxb-...
SLACK_APP_TOKEN_BACKEND=xapp-...

# Researcher Donald
SLACK_BOT_TOKEN_RESEARCHER=xoxb-...
SLACK_APP_TOKEN_RESEARCHER=xapp-...

# SecOps Donald
SLACK_BOT_TOKEN_SECOPS=xoxb-...
SLACK_APP_TOKEN_SECOPS=xapp-...

# QA Chalmers
SLACK_BOT_TOKEN_QA=xoxb-...
SLACK_APP_TOKEN_QA=xapp-...

# 위임 결과 텍스트 한도 (기본값: 3000)
# DELEGATION_RESULT_LIMIT=3000

# 회의 의견/결정 텍스트 한도 (기본값: 1000, 500)
# MEETING_OPINION_LIMIT=1000
