{
  "name": "@bifrost-platform/ui-kit-front",
  "private": false,
  "publishConfig": {
    "access": "restricted"
  },
  "version": "0.2.0",
  "type": "module",
  "homepage": "https://storybook.thebifrost.dev",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "types": [
        "dist/types.d.ts"
      ],
      "utils": [
        "dist/utils.d.ts"
      ],
      "config": [
        "dist/config.d.ts"
      ],
      "icons": [
        "dist/icons.d.ts"
      ],
      "Icon": [
        "dist/Icon.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./index.css": {
      "types": "./index.css.d.ts",
      "default": "./index.css"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.esm.js",
      "require": "./dist/icons.cjs.js"
    },
    "./Icon": {
      "types": "./dist/Icon.d.ts",
      "import": "./dist/Icon.esm.js",
      "require": "./dist/Icon.cjs.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.esm.js",
      "require": "./dist/types.cjs.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.esm.js",
      "require": "./dist/utils.cjs.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.esm.js",
      "require": "./dist/config.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "index.css",
    "index.css.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js && cp dist/index.css . && rm dist/index.css",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "gen:icons": "npx @svgr/cli --config-file svgrrc.json --template svgr-template.cjs --out-dir src/components/icons -- src/assets/icons && npx prettier --write src/components/icons",
    "prepare-release": "node --loader ts-node/esm scripts/prepare-release.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "clsx": "^2.1.1",
    "rc-slider": "^11.1.8",
    "react-toastify": "^11.0.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.2.0",
    "@eslint/js": "^8.56.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.3",
    "@storybook/addon-actions": "^7.6.12",
    "@storybook/addon-essentials": "^7.6.12",
    "@storybook/addon-interactions": "^7.6.12",
    "@storybook/addon-links": "^7.6.12",
    "@storybook/blocks": "^7.6.12",
    "@storybook/builder-vite": "^7.6.12",
    "@storybook/react": "^7.6.12",
    "@storybook/react-vite": "^7.6.12",
    "@storybook/test": "^7.6.12",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/react": "18.2.79",
    "@types/react-dom": "18.2.25",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-storybook": "^0.6.15",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.31",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "prettier": "^3.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.44.1",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-postcss": "^4.0.2",
    "semantic-release": "^24.2.5",
    "slash": "3",
    "storybook": "^7.6.12",
    "tailwindcss": "^3.3.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
