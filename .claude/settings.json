{
  "model": "sonnet",
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "allow": [
      "Read(/Users/sid/git/ai-team/**)",
      "Edit(/Users/sid/git/ai-team/.claude/agents/**)",
      "Edit(/Users/sid/git/ai-team/.claude/agents/shared/**)",
      "Edit(/Users/sid/git/ai-team/.claude/settings.json)",
      "Edit(/Users/sid/git/ai-team/.memory/**)",
      "Write(/Users/sid/git/ai-team/.memory/**)",
      "Write(/Users/sid/git/ai-team/.claude/agents/shared/**)",
      "Write(/Users/sid/git/ai-team/.claude/agents/**)",
      "Write(/Users/sid/git/ai-team/.claude/settings.json)",
      "Edit(/Users/sid/git/ai-team/.claude/skills/**)",
      "Write(/Users/sid/git/ai-team/.claude/skills/**)",
      "Edit(/Users/sid/git/ai-team/.claude/context/**)",
      "Write(/Users/sid/git/ai-team/.claude/context/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/sid/git/ai-team/.claude/hooks/guard-check.sh",
            "statusMessage": "Guard Hook 검사 중..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q '\\.md\"'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"[Token Optimization] .md 파일 수정됨 — frontmatter(date/topic/roles/summary/status) 존재 확인, 50줄 초과 시 인덱스+상세 분리, _index.md 갱신 여부 점검. 규칙: /token-optimized-docs 스킬 참조.\"}}'; fi",
            "statusMessage": "토큰 최적화 규칙 확인 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"systemMessage\":\"[Phase Check] 작업 완료 시 recommend_next_phase를 호출하여 다음 단계를 추천하세요.\"}'",
            "statusMessage": "다음 단계 확인 중..."
          }
        ]
      }
    ]
  }
}
